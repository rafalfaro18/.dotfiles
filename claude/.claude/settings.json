{
  "permissions": {
    "allow": [
      "Read(./.env.example)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)",
      "Read(./dist)",
      "Read(./.cache)",
      "Read(./venv/**)",
      "Read(./.venv/**)",
      "Read(./node_modules/**)",
      "Read(./__pycache__)",
      "Read(./.next)",
      "Read(./.DS_Store)",
      "Read(./coverage)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "tui": "fullscreen",
  "theme": "dark",
  "editorMode": "vim",
  "effortLevel": "medium",
  "statusLine": {
    "type": "command",
    "command": "oh-my-posh claude",
    "padding": 0
  }
}
