{
  "permissions": {
    "allow": [
      "Read(./.env.example)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)",
      "Read(./dist)",
      "Read(./.cache)",
      "Read(./venv/**)",
      "Read(./.venv/**)",
      "Read(./node_modules/**)",
      "Read(./__pycache__)",
      "Read(./.next)",
      "Read(./.DS_Store)",
      "Read(./coverage)",
      "Read(**/Session.vim)",
      "Bash(npx drizzle-kit migrate)",
      "Bash(drizzle-kit migrate)"
    ],
    "ask": ["WebSearch"]
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline.js",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "tui": "fullscreen",
  "theme": "custom:tokyo-night",
  "editorMode": "vim"
}
